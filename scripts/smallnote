#!/bin/zsh
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
LEGACY_APP="$ROOT/SmallNoteDesktop"
APP_BUNDLE="$ROOT/SmallNoteDesktop.app"
APP="$APP_BUNDLE/Contents/MacOS/SmallNoteDesktop"
DATA_DIR="${XIAOBIANQIAN_DATA_DIR:-$HOME/Library/Application Support/xiaobianqian}"
NOTES="$DATA_DIR/notes.json"
DELETED="$DATA_DIR/deleted.json"

mkdir -p "$DATA_DIR"

build_app_if_needed() {
  if [[ ! -x "$APP" || "$ROOT/SmallNoteDesktop.swift" -nt "$APP" || "$ROOT/smallnote" -nt "$APP_BUNDLE/Contents/Info.plist" ]]; then
    mkdir -p "$APP_BUNDLE/Contents/MacOS" "$APP_BUNDLE/Contents/Resources"
    /usr/bin/swiftc "$ROOT/SmallNoteDesktop.swift" -o "$APP" -framework AppKit -framework CoreGraphics -framework Carbon
    cat > "$APP_BUNDLE/Contents/Info.plist" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>SmallNoteDesktop</string>
  <key>CFBundleIdentifier</key>
  <string>com.andrew.xiaobianqian.desktop</string>
  <key>CFBundleName</key>
  <string>小便签</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSBackgroundOnly</key>
  <false/>
  <key>LSUIElement</key>
  <false/>
  <key>NSHighResolutionCapable</key>
  <true/>
</dict>
</plist>
EOF
  fi
}

ensure_app() {
  build_app_if_needed
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    running_path="$(ps -p "$pid" -o command= 2>/dev/null || true)"
    if [[ "$running_path" != "$APP" ]]; then
      kill "$pid" >/dev/null 2>&1 || true
    fi
  done < <(pgrep -f 'SmallNoteDesktop.app/Contents/MacOS/SmallNoteDesktop' 2>/dev/null || true)
  if ! pgrep -f "$APP$" >/dev/null 2>&1; then
    /bin/launchctl setenv XIAOBIANQIAN_CLI "$ROOT/smallnote" >/dev/null 2>&1 || true
    /bin/launchctl setenv XIAOBIANQIAN_DATA_DIR "$DATA_DIR" >/dev/null 2>&1 || true
    if [[ -n "${XIAOBIANQIAN_OBSIDIAN_VAULT:-}" ]]; then
      /bin/launchctl setenv XIAOBIANQIAN_OBSIDIAN_VAULT "$XIAOBIANQIAN_OBSIDIAN_VAULT" >/dev/null 2>&1 || true
    fi
    if [[ -n "${XIAOBIANQIAN_OBSIDIAN_NOTE:-}" ]]; then
      /bin/launchctl setenv XIAOBIANQIAN_OBSIDIAN_NOTE "$XIAOBIANQIAN_OBSIDIAN_NOTE" >/dev/null 2>&1 || true
    fi
    /usr/bin/open -j "$APP_BUNDLE"
  fi
}

case "${1:-}" in
  add)
    shift || true
    text_parts=()
    attachment_paths=()
    note_title=""
    note_tags=""
    state="text"
    for arg in "$@"; do
      case "$state" in
        text)
          if [[ "$arg" == "--" ]]; then
            state="attachments"
          elif [[ "$arg" == "--title" ]]; then
            state="expect_title"
          elif [[ "$arg" == "--tags" ]]; then
            state="expect_tags"
          else
            text_parts+=("$arg")
          fi
          ;;
        expect_title)
          note_title="$arg"
          state="text"
          ;;
        expect_tags)
          note_tags="$arg"
          state="text"
          ;;
        attachments)
          attachment_paths+=("$arg")
          ;;
      esac
    done
    text="${text_parts[*]}"
    if [[ -z "$text" ]]; then
      echo "请在 add 后面写小便签内容。"
      exit 1
    fi
    /usr/bin/python3 - "$NOTES" "$DATA_DIR" "$text" "$note_title" "$note_tags" "${attachment_paths[@]}" <<'PY'
import json
import os
import shutil
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path

path, data_dir, text = sys.argv[1], sys.argv[2], sys.argv[3]
note_title = sys.argv[4] if len(sys.argv) > 4 else ""
note_tags = sys.argv[5] if len(sys.argv) > 5 else ""
attachment_inputs = sys.argv[6:]
os.makedirs(os.path.dirname(path), exist_ok=True)
try:
    with open(path, "r", encoding="utf-8") as f:
        notes = json.load(f)
except Exception:
    notes = []

note_id = str(uuid.uuid4())
attachment_dir = Path(data_dir) / "attachments" / note_id
attachments = []

def kind_for(file_path):
    suffix = Path(file_path).suffix.lower()
    if suffix in {".png", ".jpg", ".jpeg", ".gif", ".heic", ".webp", ".tiff", ".bmp"}:
        return "image"
    if suffix == ".pdf":
        return "pdf"
    if suffix in {".md", ".markdown"}:
        return "markdown"
    return "file"

for source in attachment_inputs:
    source_path = Path(source).expanduser()
    if not source_path.is_file():
        continue
    attachment_dir.mkdir(parents=True, exist_ok=True)
    destination = attachment_dir / source_path.name
    if destination.exists():
        stem, suffix = source_path.stem, source_path.suffix
        counter = 2
        while destination.exists():
            destination = attachment_dir / f"{stem}-{counter}{suffix}"
            counter += 1
    shutil.copy2(source_path, destination)
    attachments.append({
        "name": source_path.name,
        "path": str(destination),
        "type": kind_for(source_path),
    })

notes.append({
    "id": note_id,
    "text": text,
    "color": len(notes) % 6,
    "createdAt": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    "archivedAt": None,
    "attachments": attachments,
    "title": note_title,
    "tags": note_tags,
})

with open(path, "w", encoding="utf-8") as f:
    json.dump(notes, f, ensure_ascii=False, indent=2)
PY
    ensure_app
    echo "已添加小便签。"
    ;;
  clear)
    printf "[]" > "$NOTES"
    ensure_app
    echo "已清空小便签。"
    ;;
  restore)
    /usr/bin/python3 - "$NOTES" "$DELETED" <<'PY'
import json
import os
import sys

notes_path, deleted_path = sys.argv[1], sys.argv[2]
try:
    deleted = json.load(open(deleted_path, encoding="utf-8"))
except Exception:
    deleted = []

if not deleted:
    print("没有可恢复的小便签。")
    raise SystemExit(0)

batch = deleted.pop()
try:
    current = json.load(open(notes_path, encoding="utf-8"))
except Exception:
    current = []

current_ids = {note.get("id") for note in current}
restored = [note for note in batch.get("notes", []) if note.get("id") not in current_ids]
current.extend(restored)

os.makedirs(os.path.dirname(notes_path), exist_ok=True)
with open(notes_path, "w", encoding="utf-8") as f:
    json.dump(current, f, ensure_ascii=False, indent=2)
with open(deleted_path, "w", encoding="utf-8") as f:
    json.dump(deleted, f, ensure_ascii=False, indent=2)

print(f"已恢复 {len(restored)} 条小便签。")
PY
    ensure_app
    ;;
  archive)
    shift || true
    note_id="${1:-}"
    if [[ -z "$note_id" ]]; then
      echo "请提供要存入语音笔记的小便签 ID。"
      exit 1
    fi
    /usr/bin/python3 - "$NOTES" "$note_id" <<'PY'
import json
import os
import fcntl
import shutil
import sys
from datetime import datetime
from pathlib import Path

notes_path, note_id = sys.argv[1], sys.argv[2]
vault_root_value = os.environ.get("XIAOBIANQIAN_OBSIDIAN_VAULT", "").strip()
target_value = os.environ.get("XIAOBIANQIAN_OBSIDIAN_NOTE", "").strip()

if not vault_root_value or not target_value:
    print("请先设置 XIAOBIANQIAN_OBSIDIAN_VAULT 和 XIAOBIANQIAN_OBSIDIAN_NOTE 后再归档。")
    raise SystemExit(1)

vault_root = Path(vault_root_value).expanduser()
target = Path(target_value).expanduser()
if not target.is_absolute():
    target = vault_root / target
vault_attachment_root = vault_root / "资料库/附件/小便签" / note_id

try:
    notes = json.load(open(notes_path, encoding="utf-8"))
except Exception:
    notes = []

note = next((item for item in notes if item.get("id") == note_id), None)
if not note:
    print("没有找到这条小便签。")
    raise SystemExit(1)

if note.get("archivedAt"):
    print("这条小便签已经存入语音笔记。")
    raise SystemExit(0)

text = str(note.get("text", "")).strip()
# 标题和标签在创建便签时由 AI 生成并存储，此处直接读取
title = str(note.get("title", "")).strip() or "小便签记录"
tags = str(note.get("tags", "")).strip()
attachments = note.get("attachments") or []

# 时间戳取便签创建时间
created_at = note.get("createdAt", "")
try:
    dt = datetime.fromisoformat(created_at.replace("Z", "+00:00"))
    timestamp = dt.astimezone().strftime("%Y-%m-%d %H:%M")
except Exception:
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M")

def unique_destination(directory, name):
    destination = directory / name
    if not destination.exists():
        return destination
    stem = destination.stem
    suffix = destination.suffix
    counter = 2
    while True:
        candidate = directory / f"{stem}-{counter}{suffix}"
        if not candidate.exists():
            return candidate
        counter += 1

def wiki_link_for(path, label):
    relative = path.relative_to(vault_root).as_posix()
    return f"[[{relative}|{label}]]"

def archive_attachments():
    if not attachments:
        return []
    vault_attachment_root.mkdir(parents=True, exist_ok=True)
    results = []
    for item in attachments:
        source = Path(str(item.get("path", ""))).expanduser()
        name = str(item.get("name") or source.name or "附件")
        if not source.is_file():
            results.append({"name": name, "link": name, "copied": False})
            continue
        destination = unique_destination(vault_attachment_root, name)
        shutil.copy2(source, destination)
        results.append({"name": name, "link": wiki_link_for(destination, name), "copied": True})
    return results

archived_attachments = archive_attachments()

def quote_content(value):
    parts = [line.rstrip() for line in value.strip().splitlines()]
    if archived_attachments:
        if parts:
            parts.append("")
        parts.append("附件：" + "；".join(item["link"] for item in archived_attachments))
    return "\n".join(f"> {line}" if line else ">" for line in (parts or [""]))

entry = f"\n\n#### {title}\n{quote_content(text)}\n{timestamp}\n{tags}\n"

target.parent.mkdir(parents=True, exist_ok=True)
with target.open("a", encoding="utf-8") as f:
    fcntl.flock(f.fileno(), fcntl.LOCK_EX)
    f.write(entry)
    f.flush()
    fcntl.flock(f.fileno(), fcntl.LOCK_UN)

tail = target.read_text(encoding="utf-8")[-max(500, len(entry) + 50):]
if title not in tail or (archived_attachments and archived_attachments[0]["link"] not in tail):
    raise RuntimeError("写入后验证失败。")

archive_timestamp = datetime.now().astimezone().isoformat(timespec="seconds")
for item in notes:
    if item.get("id") == note_id:
        item["archivedAt"] = archive_timestamp
        break
with open(notes_path, "w", encoding="utf-8") as f:
    json.dump(notes, f, ensure_ascii=False, indent=2)

print("已存入语音笔记。")
print(f"title={title}")
PY
    ;;
  list)
    /usr/bin/python3 - "$NOTES" <<'PY'
import json
import sys

try:
    notes = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    notes = []

if not notes:
    print("当前没有小便签。")
else:
    for idx, note in enumerate(notes, 1):
        attachments = note.get("attachments") or []
        suffix = f"（{len(attachments)} 个附件）" if attachments else ""
        print(f"{idx}. {note.get('text', '')}{suffix}")
PY
    ;;
  open)
    ensure_app
    echo "小便签桌面程序已打开。"
    ;;
  stop)
    pkill -f 'SmallNoteDesktop.app/Contents/MacOS/SmallNoteDesktop' >/dev/null 2>&1 || true
    pkill -f "$LEGACY_APP$" >/dev/null 2>&1 || true
    echo "小便签桌面程序已关闭。"
    ;;
  doctor)
    build_app_if_needed
    echo "目标程序：$APP"
    echo "运行中的 SmallNoteDesktop："
    pgrep -fl SmallNoteDesktop || echo "  未运行"
    echo "当前便签数据：$NOTES"
    if [[ -f "$NOTES" ]]; then
      /usr/bin/python3 - "$NOTES" <<'PY'
import json
import sys
try:
    notes = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    notes = []
print(f"便签数量：{len(notes)}")
PY
    else
      echo "便签数量：0"
    fi
    ;;
  *)
    cat <<'EOF'
用法：
  smallnote add 你的内容
  smallnote list
  smallnote clear
  smallnote restore
  smallnote archive NOTE_ID
  smallnote open
  smallnote stop
EOF
    ;;
esac
